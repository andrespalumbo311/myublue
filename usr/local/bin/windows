#!/bin/bash
# Windows 11 launcher with automatic container lifecycle management

CONTAINER_NAME="windows11"
IMAGE="dockurr/windows"
DATA_DIR="/var/home/andres/Documents/windows/data"
REMMINA_PROFILE="/var/home/andres/.local/share/remmina/windows11.remmina"
MAX_WAIT=300  # 5 minutes for first boot

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Detect if running inside a container
if [ -f /run/.containerenv ] || [ -f /.dockerenv ]; then
    PODMAN_CMD="distrobox-host-exec podman"
    FLATPAK_CMD="distrobox-host-exec flatpak"
else
    PODMAN_CMD="podman"
    FLATPAK_CMD="flatpak"
fi

# Check if container exists
if ! $PODMAN_CMD container exists "$CONTAINER_NAME" 2>/dev/null; then
    log_info "Creating Windows 11 container (first time setup)..."
    $PODMAN_CMD run -d \
        --name "$CONTAINER_NAME" \
        --device=/dev/kvm \
        -p 3389:3389 \
        -p 8006:8006 \
        -v "$DATA_DIR:/storage:Z" \
        -e RAM_SIZE="8G" \
        -e CPU_CORES="2" \
        -e VERSION="win11" \
        -e PASSWORD="password" \
        --restart=unless-stopped \
        --userns=host \
        "$IMAGE"
else
    log_info "Starting existing Windows 11 container..."
    $PODMAN_CMD start "$CONTAINER_NAME"
fi

# Wait for container and RDP
log_info "Container started successfully."
log_info "You can connect manually via:"
log_info "   1. RDP (Remmina): 127.0.0.1:3389 (User: Docker, Pass: password)"
log_info "   2. Web Console:   http://127.0.0.1:8006"

exit 0
