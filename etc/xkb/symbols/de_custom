// Custom German keyboard layout that swaps ß and ?
// Based on standard German (de) layout.
// Key AE11 (next to zero) is modified: 
// - Default: ?
// - Shift: ß
// - AltGr: \ (unchanged)

partial alphanumeric_keys
xkb_symbols "swap_ssharp_question" {
    include "de(basic)"
    key <AE11> { [ question, ssharp, backslash ] };
};
