[Unit]
Description=SCX eBPF Scheduler
Documentation=https://github.com/sched-ext/scx
After=network.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/scx
# Avviamo direttamente lo scheduler scelto per garantire l'attivazione al boot
ExecStart=/usr/bin/${SCX_SCHEDULER}
# Assicura che se il manager cambia lo scheduler, il servizio non vada in conflitto
ExecStop=/usr/bin/scxctl stop
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
