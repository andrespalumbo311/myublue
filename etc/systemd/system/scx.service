[Unit]
Description=SCX eBPF Scheduler
Documentation=https://github.com/sched-ext/scx
After=network.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/scx
ExecStart=/bin/sh -c "exec /usr/bin/$${SCX_SCHEDULER:-scx_lavd} --kconfig \"$$(grep '=y' /lib/modules/$$(uname -r)/config | tr '\\n' ' ')\" "
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
